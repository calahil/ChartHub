<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChartHub.Hud.ViewModels"
        x:Class="ChartHub.Hud.Views.HudWindow"
        x:DataType="vm:HudViewModel"
        WindowState="FullScreen"
        SystemDecorations="None"
        Topmost="True"
        Background="#FF0F0F0F"
        Title="ChartHub">

    <!-- Root grid: centered logo + bottom-right status overlay -->
    <Grid>

        <!-- Logo centered in the screen -->
        <Image Source="avares://ChartHub.Hud/Resources/logo-1024.png"
               Width="512"
               Height="512"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform" />

        <!-- Status overlay: bottom-right corner -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,32,32"
                    Spacing="10">

            <!-- Connection indicator dot -->
            <Ellipse Width="16"
                     Height="16"
                     VerticalAlignment="Center"
                     Fill="{Binding IndicatorColor}" />

            <!-- Device count label -->
            <TextBlock Text="{Binding DeviceCountLabel}"
                       Foreground="#FFCCCCCC"
                       FontSize="18"
                       VerticalAlignment="Center" />

        </StackPanel>

    </Grid>

</Window>
