<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChartHub.Hud.ViewModels"
        x:Class="ChartHub.Hud.Views.HudWindow"
        x:DataType="vm:HudViewModel"
        WindowState="FullScreen"
        WindowDecorations="None"
        Topmost="True"
        Background="#FF0F0F0F"
        Title="ChartHub">

    <!-- Root grid: 64px status strip on top, logo fills remaining space, 28px version strip at bottom -->
    <Grid RowDefinitions="64,*,28">

        <!-- Top strip -->
        <Border Grid.Row="0"
                Background="#FF1A1A1A">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Device name (hostname + email) -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="24,0">
                    <TextBlock Text="{Binding DeviceName}"
                               Foreground="#FFCCCCCC"
                               FontSize="20"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" ("
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="{Binding UserEmail}"
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text=")"
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Connection indicator dot (right) -->
                <Ellipse Grid.Column="1"
                         Width="16"
                         Height="16"
                         VerticalAlignment="Center"
                         Margin="0,0,24,0"
                         Fill="{Binding IndicatorColor}" />

            </Grid>
        </Border>

        <!-- Logo centered in remaining space -->
        <Image Grid.Row="1"
               Source="avares://ChartHub.Hud/Resources/logo-1024.png"
               Width="{Binding LogoSize}"
               Height="{Binding LogoSize}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform" />

        <!-- Bottom-right volume widget (always visible) -->
        <Border Grid.RowSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
            Margin="0,0,28,28"
                Background="#CC1A1A1A"
            BorderBrush="#553A3A3A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14,12"
                Opacity="{Binding VolumeWidgetOpacity}">
            <StackPanel Spacing="6"
                        HorizontalAlignment="Center">
                <TextBlock Text="VOL"
                           Foreground="#FFCCCCCC"
                   FontSize="10"
                   FontWeight="SemiBold"
                           HorizontalAlignment="Center" />

            <Border Background="#33202020"
                CornerRadius="6"
                Padding="6,2"
                HorizontalAlignment="Center"
                IsVisible="{Binding IsMuted}">
                <TextBlock Text="MUTE"
                       Foreground="{Binding VolumeValueBrush}"
                       FontSize="9"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            </Border>

            <Border Width="20"
                        Height="{Binding VolumeBarHeight}"
                        Background="{Binding VolumeTrackDisplayBrush}"
                BorderBrush="#44404040"
                BorderThickness="1"
                CornerRadius="10"
                        Padding="2"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Border Height="{Binding VolumeFillHeight}"
                                Background="{Binding VolumeValueBrush}"
                                CornerRadius="6"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </Border>

                <TextBlock Text="{Binding VolumeLabel}"
                           Foreground="{Binding VolumeValueBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Version strip (bottom-left) -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Version}"
                   Foreground="#FF666666"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="16,0"
                   IsVisible="{Binding Version, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    </Grid>

</Window>
