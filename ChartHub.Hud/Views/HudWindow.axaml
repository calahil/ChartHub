<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChartHub.Hud.ViewModels"
        x:Class="ChartHub.Hud.Views.HudWindow"
        x:DataType="vm:HudViewModel"
        WindowState="FullScreen"
        SystemDecorations="None"
        Topmost="True"
        Background="#FF0F0F0F"
        Title="ChartHub">

    <!-- Root grid: 64px status strip on top, logo fills remaining space -->
    <Grid RowDefinitions="64,*">

        <!-- Top strip -->
        <Border Grid.Row="0"
                Background="#FF1A1A1A">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Device hostname (left) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding DeviceName}"
                           Foreground="#FFCCCCCC"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="24,0" />

                <!-- Connection indicator dot (right) -->
                <Ellipse Grid.Column="1"
                         Width="16"
                         Height="16"
                         VerticalAlignment="Center"
                         Margin="0,0,24,0"
                         Fill="{Binding IndicatorColor}" />

            </Grid>
        </Border>

        <!-- Logo centered in remaining space -->
        <Image Grid.Row="1"
               Source="avares://ChartHub.Hud/Resources/logo-1024.png"
               Width="512"
               Height="512"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform" />

    </Grid>

</Window>
