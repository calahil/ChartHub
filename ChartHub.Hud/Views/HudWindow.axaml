<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChartHub.Hud.ViewModels"
        x:Class="ChartHub.Hud.Views.HudWindow"
        x:DataType="vm:HudViewModel"
        WindowState="FullScreen"
        SystemDecorations="None"
        Topmost="True"
        Background="#FF0F0F0F"
        Title="ChartHub">

    <!-- Root grid: 64px status strip on top, logo fills remaining space, 28px version strip at bottom -->
    <Grid RowDefinitions="64,*,28">

        <!-- Top strip -->
        <Border Grid.Row="0"
                Background="#FF1A1A1A">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Device name (hostname + email) -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="24,0">
                    <TextBlock Text="{Binding DeviceName}"
                               Foreground="#FFCCCCCC"
                               FontSize="20"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" ("
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="{Binding UserEmail}"
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text=")"
                               Foreground="#FF7BA7E0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Connection indicator dot (right) -->
                <Ellipse Grid.Column="1"
                         Width="16"
                         Height="16"
                         VerticalAlignment="Center"
                         Margin="0,0,24,0"
                         Fill="{Binding IndicatorColor}" />

            </Grid>
        </Border>

        <!-- Logo centered in remaining space -->
        <Image Grid.Row="1"
               Source="avares://ChartHub.Hud/Resources/logo-1024.png"
               Width="512"
               Height="512"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform" />

        <!-- Version strip (bottom-left) -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Version}"
                   Foreground="#FF666666"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="16,0"
                   IsVisible="{Binding Version, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    </Grid>

</Window>
