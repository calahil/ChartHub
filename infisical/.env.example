# Infisical environment configuration
# Copy this file to infisical/.env and fill in the values before starting the stack.
# This file must NEVER be committed to source control.

# --- Database ---
INFISICAL_DB_USER=infisical
INFISICAL_DB_PASSWORD=CHANGE_ME
INFISICAL_DB_NAME=infisical

# --- Redis ---
INFISICAL_REDIS_PASSWORD=CHANGE_ME

# --- Infisical app ---
# Generate with: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=CHANGE_ME_32_HEX_CHARS

# Generate with: openssl rand -base64 32
INFISICAL_AUTH_SECRET=CHANGE_ME

# The public URL this instance is accessible at (used for OAuth callbacks and links in emails)
INFISICAL_SITE_URL=http://YOUR_SERVER_IP:8080

# Port to expose on the host
INFISICAL_PORT=8080

# --- SMTP (optional but strongly recommended — needed for invites and password reset) ---
# Leave blank to disable email. Use any SMTP relay (Mailgun free tier, Gmail app password, etc.)
INFISICAL_SMTP_HOST=
INFISICAL_SMTP_PORT=587
INFISICAL_SMTP_USERNAME=
INFISICAL_SMTP_PASSWORD=
INFISICAL_SMTP_FROM_ADDRESS=noreply@example.com
INFISICAL_SMTP_FROM_NAME=Infisical
