{
  "Database": {
    "Provider": "postgresql",
    "PostgreSqlConnectionString": "Host=localhost;Port=5432;Database=charthub_backup;Username=postgres;Password=CHANGE_ME",
    "SqliteConnectionString": "Data Source=charthub-backup.db"
  },
  "RhythmVerseSource": {
    "BaseUrl": "https://rhythmverse.co/",
    "SongsPath": "api/all/songfiles/list",
    "Token": ""
  },
  "Sync": {
    "Enabled": true,
    "IntervalMinutes": 10080,
    "RecordsPerPage": 100,
    "MaxPagesPerRun": 2000,
    "InitialDelayMinutes": 0
  },
  "Downloads": {
    "Mode": "redirect",
    "CacheDirectory": "./cache/downloads",
    "ExternalRedirectCacheHours": 48
  },
  "ImageCache": {
    "CacheDirectory": "./cache/images"
  },
  "Logging": {
    "Sink": {
      "SinkTableName": "Logs",
      "RetentionDays": 90,
      "BatchSizeLimit": 50,
      "PeriodSeconds": 5
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
