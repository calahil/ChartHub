{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Desktop: Debug ChartHub",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-desktop",
            "program": "${workspaceFolder}/ChartHub/bin/Debug/net10.0/ChartHub.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "API: Debug ChartHub.BackupApi",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-backup-api",
            "program": "${workspaceFolder}/ChartHub.BackupApi/bin/Debug/net10.0/ChartHub.BackupApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.BackupApi",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "API: Debug ChartHub.Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-server-api",
            "program": "${workspaceFolder}/ChartHub.Server/bin/Debug/net10.0/ChartHub.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.Server",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://0.0.0.0:5180",
                "Auth__JwtSigningKey": "dev_only_local_jwt_key_1234567890_abcd"
            }
        },
        {
            "name": "Server: Local Debug (dev-data + .env.local)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-server-api",
            "program": "${workspaceFolder}/ChartHub.Server/bin/Debug/net10.0/ChartHub.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.Server",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://0.0.0.0:5180",
                "ServerPaths__ConfigRoot": "${workspaceFolder}/dev-data/config",
                "ServerPaths__ChartHubRoot": "${workspaceFolder}/dev-data/data",
                "ServerPaths__DownloadsDir": "${workspaceFolder}/dev-data/data/downloads",
                "ServerPaths__StagingDir": "${workspaceFolder}/dev-data/data/staging",
                "ServerPaths__CloneHeroRoot": "${workspaceFolder}/dev-data/music",
                "ServerPaths__SqliteDbPath": "${workspaceFolder}/dev-data/db/charthub.db",
                "ServerLogging__LogDirectory": "${workspaceFolder}/dev-data/logs",
                "ServerLogging__FileName": "charthub-server.log",
                "CHARTHUB_SERVER_PORT": "5180"
            }
        },
        {
            "name": "Runner: Register Local Dev Runner",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash -lc \"set -euo pipefail; export HOME=\\\"${workspaceFolder}/dev-data\\\"; LOCAL_SERVER_URL=\\\"${LOCAL_RUNNER_SERVER_URL:-http://10.0.0.7:5180}\\\"; mkdir -p \\\"$HOME\\\"; if [[ -f \\\"${workspaceFolder}/.env.local\\\" ]]; then set -a; . \\\"${workspaceFolder}/.env.local\\\"; set +a; LOCAL_SERVER_URL=\\\"${LOCAL_RUNNER_SERVER_URL:-$LOCAL_SERVER_URL}\\\"; fi; PAYLOAD=\\\"{\\\\\\\"ttlMinutes\\\\\\\":15}\\\"; TOKEN=$(curl -fsS -X POST -H \\\"X-Runner-Api-Key: a5c4f05d39705837a865d9cca107137ed0bc79dde61d45fc1a6a8e9803983e9a\\\" -H \\\"Content-Type: application/json\\\" --data \\\"$PAYLOAD\\\" \\\"$LOCAL_SERVER_URL/api/v1/runners/registration-tokens\\\" | python3 -c \\\"import json,sys; print(json.load(sys.stdin).get(\\\\\\\"plainToken\\\\\\\", \\\\\\\"\\\\\\\"))\\\"); if [[ -z \\\"$TOKEN\\\" ]]; then echo \\\"Failed to obtain registration token from $LOCAL_SERVER_URL\\\"; exit 1; fi; dotnet run --project \\\"${workspaceFolder}/ChartHub.TranscriptionRunner/ChartHub.TranscriptionRunner.csproj\\\" -- register --server \\\"$LOCAL_SERVER_URL\\\" --token \\\"$TOKEN\\\" --name local-dev-runner --concurrency 1\""
        },
        {
            "name": "Runner: Debug Local Runner",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "prepare-local-dev-runner",
            "program": "${workspaceFolder}/ChartHub.TranscriptionRunner/bin/Debug/net10.0/ChartHub.TranscriptionRunner.dll",
            "args": [
                "run",
                "--config",
                "${workspaceFolder}/dev-data/.charthub-runner/config.json"
            ],
            "cwd": "${workspaceFolder}/ChartHub.TranscriptionRunner",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "HOME": "${workspaceFolder}/dev-data"
            }
        },
        {
            "name": "Android: Install To Emulator (emulator-5554)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=emulator-5554 -p:RuntimeIdentifier=android-x64 -p:EmbedAssembliesIntoApk=true -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        },
        {
            "name": "Android: Install To Phone (R5CY10G7DWP)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=R5CY10G7DWP -p:RuntimeIdentifier=android-arm64 -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        },
        {
            "name": "Android: Debug Emulator (emulator-5554)",
            "type": "mono",
            "request": "attach",
            "preLaunchTask": "run-debug-android-emulator",
            "address": "localhost",
            "port": 10001
        },
        {
            "name": "Android: Debug Phone (R5CY10G7DWP)",
            "type": "mono",
            "request": "attach",
            "preLaunchTask": "run-debug-android-phone",
            "address": "localhost",
            "port": 10002
        },
        {
            "name": "Android: Attach To Phone (R5CY10G7DWP)",
            "type": "mono",
            "request": "attach",
            "address": "localhost",
            "port": 10002
        },
        {
            "name": "Android: Attach To Emulator (emulator-5554)",
            "type": "mono",
            "request": "attach",
            "address": "localhost",
            "port": 10001
        }
    ],
    "compounds": [
        {
            "name": "Desktop + BackupApi",
            "configurations": [
                "Desktop: Debug ChartHub",
                "API: Debug ChartHub.BackupApi"
            ],
            "stopAll": true
        },
        {
            "name": "Desktop + ServerApi",
            "configurations": [
                "Desktop: Debug ChartHub",
                "API: Debug ChartHub.Server"
            ],
            "stopAll": true
        },
        {
            "name": "Server + Runner (Local Dev)",
            "configurations": [
                "Server: Local Debug (dev-data + .env.local)",
                "Runner: Debug Local Runner"
            ],
            "stopAll": true
        }
    ]
}
