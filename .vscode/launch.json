{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Desktop: Debug ChartHub",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/ChartHub/bin/Debug/net10.0/ChartHub.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "API: Debug ChartHub.BackupApi",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-backup-api",
            "program": "${workspaceFolder}/ChartHub.BackupApi/bin/Debug/net10.0/ChartHub.BackupApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.BackupApi",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            {
                "name": "ChartHub Desktop (net10.0)",
                "type": "coreclr",
                "request": "launch",
                "preLaunchTask": "build-desktop",
                "program": "${workspaceFolder}/ChartHub/bin/Debug/net10.0/ChartHub.dll",
                "args": [],
                "cwd": "${workspaceFolder}/ChartHub",
                "stopAtEntry": false,
                "console": "internalConsole"
            },
            {
                "name": "ChartHub Android (net10.0-android)",
                "type": "coreclr",
                "request": "launch",
                "preLaunchTask": "build-android",
                "program": "${workspaceFolder}/ChartHub/bin/Debug/net10.0-android/ChartHub.dll",
                "args": [],
                "cwd": "${workspaceFolder}/ChartHub",
                "stopAtEntry": false,
                "console": "internalConsole"
            }
        {
            "name": "Android: Install To Tablet Emulator (emulator-5556)",
            "type": "node-terminal",
            "request": "launch",
            "command": "TABLET_AVD=${TABLET_AVD:-Medium_Tablet_API_36.1}; if ! ${HOME}/Android/Sdk/platform-tools/adb devices | grep -q '^emulator-5556\\s'; then if ! ${HOME}/Android/Sdk/emulator/emulator -list-avds | grep -qx \"$TABLET_AVD\"; then echo \"Tablet AVD '$TABLET_AVD' not found. Set TABLET_AVD to an installed AVD name.\"; exit 1; fi; ${HOME}/Android/Sdk/emulator/emulator -avd \"$TABLET_AVD\" -port 5556 -netdelay none -netspeed full -no-snapshot-load -no-snapshot-save >/tmp/charthub-tablet-emulator.log 2>&1 & fi; ${HOME}/Android/Sdk/platform-tools/adb -s emulator-5556 wait-for-device; until [ \"$(${HOME}/Android/Sdk/platform-tools/adb -s emulator-5556 shell getprop sys.boot_completed 2>/dev/null | tr -d '\\r')\" = \"1\" ]; do sleep 2; done; until ${HOME}/Android/Sdk/platform-tools/adb -s emulator-5556 shell cmd package list packages >/dev/null 2>&1; do sleep 2; done; dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=emulator-5556 -p:RuntimeIdentifier=android-x64 -p:EmbedAssembliesIntoApk=true -p:AndroidSdkDirectory=${HOME}/Android/Sdk"
        },
        {
            "name": "Android: Install To Phone (R5CY10G7DWP)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=R5CY10G7DWP -p:RuntimeIdentifier=android-arm64 -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        },
            {
                "name": "Android: Debug Phone (R5CY10G7DWP)",
                "type": "mono",
                "request": "attach",
                "preLaunchTask": "run-debug-android-phone",
                "address": "localhost",
                "port": 10001
            },
            {
                "name": "Android: Attach To Phone (R5CY10G7DWP)",
                "type": "mono",
                "request": "attach",
                "address": "localhost",
                "port": 10001
            },
        {
            "name": "Android: Install To Tablet (8601SFCECH00000272)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=8601SFCECH00000272 -p:RuntimeIdentifier=android-arm64 -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        }
    ],
    "compounds": [
        {
            "name": "Desktop + BackupApi",
            "configurations": [
                "Desktop: Debug ChartHub",
                "API: Debug ChartHub.BackupApi"
            ],
            "stopAll": true
        }
    ]
}
