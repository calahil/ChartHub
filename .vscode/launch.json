{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Desktop: Debug ChartHub",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-desktop",
            "program": "${workspaceFolder}/ChartHub/bin/Debug/net10.0/ChartHub.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "API: Debug ChartHub.BackupApi",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-backup-api",
            "program": "${workspaceFolder}/ChartHub.BackupApi/bin/Debug/net10.0/ChartHub.BackupApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.BackupApi",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "API: Debug ChartHub.Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-server-api",
            "program": "${workspaceFolder}/ChartHub.Server/bin/Debug/net10.0/ChartHub.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ChartHub.Server",
            "stopAtEntry": false,
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://0.0.0.0:5180",
                "Auth__JwtSigningKey": "dev_only_local_jwt_key_1234567890_abcd"
            }
        },
        {
            "name": "Android: Install To Emulator (emulator-5554)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=emulator-5554 -p:RuntimeIdentifier=android-x64 -p:EmbedAssembliesIntoApk=true -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        },
        {
            "name": "Android: Install To Phone (R5CY10G7DWP)",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/ChartHub/ChartHub.csproj -t:Install -p:EnableAndroid=true -f net10.0-android -p:Device=R5CY10G7DWP -p:RuntimeIdentifier=android-arm64 -p:AndroidSdkDirectory=$HOME/Android/Sdk"
        },
        {
            "name": "Android: Debug Emulator (emulator-5554)",
            "type": "mono",
            "request": "attach",
            "preLaunchTask": "run-debug-android-emulator",
            "address": "localhost",
            "port": 10001
        },
        {
            "name": "Android: Debug Phone (R5CY10G7DWP)",
            "type": "mono",
            "request": "attach",
            "preLaunchTask": "run-debug-android-phone",
            "address": "localhost",
            "port": 10002
        },
        {
            "name": "Android: Attach To Phone (R5CY10G7DWP)",
            "type": "mono",
            "request": "attach",
            "address": "localhost",
            "port": 10002
        },
        {
            "name": "Android: Attach To Emulator (emulator-5554)",
            "type": "mono",
            "request": "attach",
            "address": "localhost",
            "port": 10001
        }
    ],
    "compounds": [
        {
            "name": "Desktop + BackupApi",
            "configurations": [
                "Desktop: Debug ChartHub",
                "API: Debug ChartHub.BackupApi"
            ],
            "stopAll": true
        },
        {
            "name": "Desktop + ServerApi",
            "configurations": [
                "Desktop: Debug ChartHub",
                "API: Debug ChartHub.Server"
            ],
            "stopAll": true
        }
    ]
}
