<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ChartHub.Controls;assembly=ChartHub"
             xmlns:utilities="clr-namespace:ChartHub.Utilities;assembly=ChartHub"
             xmlns:strings="clr-namespace:ChartHub.Strings;assembly=ChartHub"
             x:Class="ChartHub.Controls.SongRatingControl">

       <UserControl.Resources>
              <utilities:AssetPathToImageConverter x:Key="AssetPathToImageConverter" />
       </UserControl.Resources>

       <StackPanel>
              <StackPanel x:Name="EncoreRatings">

                     <Grid x:Name="SongRatingGrid"
                           IsVisible="{Binding IsDesktopMode, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                           ColumnDefinitions="*,3*"
                           RowDefinitions="*, *, *, *, *">
                            <!-- Drum Rating -->
                            <Border Padding="8,2"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <Image Source="{Binding Source={x:Static strings:UiIcons.DrumsSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                          Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            </Border>
                            <Border Padding="8,2"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <controls:StarRatingControl Rating="{Binding DrumString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                            </Border>
                            <!-- Guitar Rating -->
                            <Border Padding="8,2"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <Image Source="{Binding Source={x:Static strings:UiIcons.GuitarSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                          Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            </Border>
                            <Border Padding="8,2"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <controls:StarRatingControl Rating="{Binding GuitarString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                            </Border>
                            <!-- Keyboard Rating -->
                            <Border Padding="8,2"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <Image Source="{Binding Source={x:Static strings:UiIcons.KeysSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                          Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            </Border>
                            <Border Padding="8,2"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <controls:StarRatingControl Rating="{Binding KeysString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                            </Border>
                            <!-- Bass Rating -->
                            <Border Padding="8,2"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <Image Source="{Binding Source={x:Static strings:UiIcons.BassSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                          Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            </Border>
                            <Border Padding="8,2"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <controls:StarRatingControl Rating="{Binding BassString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                            </Border>
                            <!-- Vocals Rating -->
                            <Border Padding="8,2"
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <Image Source="{Binding Source={x:Static strings:UiIcons.VocalsSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                          Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            </Border>
                            <Border Padding="8,2"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="0,0,8,8"
                                    CornerRadius="10"
                                    Background="{StaticResource ThemeControlMidBrush}">
                                   <controls:StarRatingControl Rating="{Binding VocalString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                            </Border>
                     </Grid>
                     <Grid x:Name="SongRatingMinGrid"
                           IsVisible="{Binding IsCompanionMode, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                           ColumnDefinitions="Auto,Auto,*,Auto"
                           RowDefinitions="*, *, *">
                            <!-- Drum Rating -->
                            <Image Source="{Binding Source={x:Static strings:UiIcons.DrumsSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   VerticalAlignment="Top"
                                   Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            <controls:StarRatingControl Rating="{Binding DrumString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource ThemeAccentBrush}"/>
                            <!-- Guitar Rating -->
                            <Image Source="{Binding Source={x:Static strings:UiIcons.GuitarSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                   Grid.Row="0"
                                   Grid.Column="2"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Right"
                                   Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            <controls:StarRatingControl Rating="{Binding GuitarString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        Grid.Row="0"
                                                        Grid.Column="3"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource ThemeAccentBrush}"/>
                            <!-- Keyboard Rating -->
                            <Image Source="{Binding Source={x:Static strings:UiIcons.KeysSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Right"
                                   Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            <controls:StarRatingControl Rating="{Binding KeysString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        FontWeight="Bold" />
                            <!-- Bass Rating -->
                            <Image Source="{Binding Source={x:Static strings:UiIcons.BassSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Right"
                                   Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            <controls:StarRatingControl Rating="{Binding BassString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        Grid.Row="1"
                                                        Grid.Column="3"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource ThemeAccentBrush}"/>
                            <!-- Vocals Rating -->
                            <Image Source="{Binding Source={x:Static strings:UiIcons.VocalsSmall}, Converter={StaticResource AssetPathToImageConverter}}"
                                   Grid.Row="2"
                                   Grid.Column="0"
                                   VerticalAlignment="Top"
                                   Height="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}" />
                            <controls:StarRatingControl Rating="{Binding VocalString, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        GlyphWidth="{Binding GlyphWidth, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        FontSize="{Binding GlyphFontSize, RelativeSource={RelativeSource AncestorType=controls:SongRatingControl}}"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource ThemeAccentBrush}"/>
                     </Grid>
              </StackPanel>
              
       </StackPanel>
</UserControl>