<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             x:Class="ChartHub.Views.SettingsView"
             x:Name="SettingsViewRoot"
             x:DataType="viewmodels:SettingsViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
          Margin="12">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,*">
            <Button Grid.Column="0"
                    Content="Save"
                    Command="{Binding SaveCommand}" />
            <Button Grid.Column="1"
                Margin="8,0,0,0"
                    Content="Reload"
                    Command="{Binding ReloadCommand}" />
            <TextBlock Grid.Column="2"
                   Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}" />
        </Grid>

        <Border Grid.Row="1"
            Margin="0,8,0,0"
            Padding="8,6"
            Background="{StaticResource ThemeControlMidBrush}"
            BorderBrush="{StaticResource SemanticWarning}"
            BorderThickness="1"
            CornerRadius="6"
            IsVisible="{Binding HasValidationErrors}">
            <StackPanel Spacing="6">
                <TextBlock Text="Fix highlighted fields before saving."
                           Foreground="{StaticResource SemanticWarning}" />
                <ItemsControl ItemsSource="{Binding ValidationIssueSummaries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemHeight="26" ItemWidth="160" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,6,0"
                                    Padding="8,2"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource SemanticWarning}"
                                    Background="{StaticResource ThemeControlLowBrush}">
                                <TextBlock Text="{Binding .}"
                                           FontSize="11"
                                           Foreground="{StaticResource ThemeForegroundBrush}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,8,0,8"
                Padding="8,6"
                Background="{StaticResource ThemeControlMidBrush}"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                BorderThickness="1"
                CornerRadius="6"
                IsVisible="{Binding HasPendingRestartSettings}">
            <TextBlock Text="Some settings may require restart to take full effect."
                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
        </Border>

        <Border Grid.Row="3"
                Margin="0,0,0,8"
                Padding="10"
                BorderThickness="1"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                Background="{StaticResource ThemeControlLowBrush}"
                CornerRadius="6">
            <StackPanel Spacing="8">
                <TextBlock Text="Secrets"
                           FontSize="16"
                           FontWeight="Bold" />

                <TextBlock Text="Secret values are stored in secure storage and never written to appsettings.json."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ThemeForegroundLowBrush}" />

                <Border Padding="8,4"
                        CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{StaticResource ThemeBorderMidBrush}"
                        Background="{StaticResource ThemeControlMidBrush}">
                    <TextBlock Text="{Binding SecretStorageBackend, StringFormat='Storage Backend: {0}'}"
                               FontSize="12"
                               Foreground="{StaticResource ThemeForegroundLowBrush}" />
                </Border>

                <ItemsControl ItemsSource="{Binding Secrets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Margin="0,4,0,0"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                    Background="{StaticResource ThemeControlMidBrush}"
                                    CornerRadius="6">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="3"
                                               Text="{Binding Label}"
                                               FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="3"
                                               Margin="0,4,0,0"
                                               Text="{Binding Description}"
                                               Foreground="{StaticResource ThemeForegroundLowBrush}"
                                               TextWrapping="Wrap" />

                                    <TextBox Grid.Row="2"
                                             Grid.Column="0"
                                             Margin="0,8,8,0"
                                             Text="{Binding Value}"
                                             PasswordChar="*"
                                             Watermark="Enter new value" />

                                    <Button Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,8,8,0"
                                            Content="Save"
                                            Command="{Binding #SettingsViewRoot.DataContext.SaveSecretCommand}"
                                            CommandParameter="{Binding}" />

                                    <Button Grid.Row="2"
                                            Grid.Column="2"
                                            Margin="0,8,0,0"
                                            Content="Clear"
                                            Command="{Binding #SettingsViewRoot.DataContext.ClearSecretCommand}"
                                            CommandParameter="{Binding}" />

                                    <Border Grid.Row="0"
                                            Grid.Column="2"
                                            Padding="6,2"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource ThemeControlLowBrush}">
                                        <TextBlock Text="{Binding StorageStatus}"
                                                   FontSize="11" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto">
            <ListBox ItemsSource="{Binding Fields}"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Group}"
                                       Margin="0,10,0,4"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       IsVisible="{Binding IsGroupHeaderVisible}" />

                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                    Background="{StaticResource ThemeControlLowBrush}"
                                    CornerRadius="6">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />

                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                          Margin="8,0,0,0"
                                            Padding="6,2"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource ThemeControlMidBrush}">
                                        <TextBlock Text="{Binding IsHotReloadable, StringFormat='Hot Reload: {0}'}"
                                                   FontSize="11" />
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,4,0,0"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource ThemeForegroundLowBrush}"
                                               IsVisible="{Binding HasDescription}" />

                                                                        <TextBox Grid.Row="2"
                                                                                         Grid.ColumnSpan="2"
                                                                                         Margin="0,8,0,0"
                                                                                         Text="{Binding StringValue}"
                                                                                         IsVisible="{Binding IsTextEditor}" />

                                                                        <Grid Grid.Row="2"
                                                                                    Grid.ColumnSpan="2"
                                                                                    Margin="0,8,0,0"
                                                                                    ColumnDefinitions="*,Auto"
                                                                                    IsVisible="{Binding IsPathPicker}">
                                                                                <TextBox Grid.Column="0"
                                                                                                 Text="{Binding StringValue}" />
                                                                                <Button Grid.Column="1"
                                                                                                Margin="8,0,0,0"
                                                                                                MinHeight="34"
                                                                                                Content="{Binding BrowseButtonText}"
                                                                                                Click="OnBrowsePathClick" />
                                                                        </Grid>

                                    <ToggleSwitch Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding BoolValue}"
                                                  IsVisible="{Binding IsToggleEditor}" />

                                    <NumericUpDown Grid.Row="2"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,8,0,0"
                                                   Value="{Binding NumberValue}"
                                                   Minimum="-1000000"
                                                   Maximum="1000000"
                                                   Increment="1"
                                                   IsVisible="{Binding IsNumberEditor}" />

                                    <ComboBox Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Margin="0,8,0,0"
                                              ItemsSource="{Binding Options}"
                                              SelectedItem="{Binding SelectedOption}"
                                              IsVisible="{Binding IsDropdownEditor}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.ColumnSpan="2"
                                               Margin="0,6,0,0"
                                               Text="{Binding ErrorMessage}"
                                               Foreground="{StaticResource SemanticError}"
                                               IsVisible="{Binding HasError}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>
