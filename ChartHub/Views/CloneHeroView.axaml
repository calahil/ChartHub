<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ChartHub.Views.CloneHeroView"
             x:DataType="viewmodels:CloneHeroViewModel">

    <Grid Margin="10" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBlock Text="Clone Hero Library"
                       FontSize="18"
                       FontWeight="Bold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh Library"
                        Command="{Binding RefreshLibraryCommand}" />
                <Button Content="Restore Last Deleted"
                    Command="{Binding RestoreLastDeletedSongCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
            IsVisible="{Binding ShowPostStartupStatus}"
                Margin="0,0,0,10"
                Padding="8"
                BorderThickness="1"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                Background="{StaticResource ThemeControlLowBrush}">
            <TextBlock Text="{Binding ReconciliationStatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding ShowStartupBlockingState}"
                Margin="0,0,0,10"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                Background="{StaticResource ThemeControlLowBrush}">
            <StackPanel Spacing="6">
                <TextBlock Text="Preparing Clone Hero library..."
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding ReconciliationStatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ThemeForegroundLowBrush}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="280,*" IsVisible="{Binding IsDesktopMode}">
            <Border Grid.Column="0" Margin="0,0,10,0" BorderThickness="1" BorderBrush="{StaticResource ThemeBorderMidBrush}" Padding="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Artists" FontWeight="SemiBold" />
                    <ListBox ItemsSource="{Binding Artists}"
                             SelectedItem="{Binding SelectedArtist}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" BorderBrush="{StaticResource ThemeBorderMidBrush}" Padding="8">
                <DataGrid ItemsSource="{Binding Songs}"
                          SelectedItem="{Binding SelectedSong}"
                          CanUserSortColumns="True"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="180" />
                        <DataGridTextColumn Header="Charter" Binding="{Binding Charter}" Width="180" />
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete Song (Server)" Command="{Binding DeleteSongCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsCompanionMode}">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                <Button Content="Back"
                        Command="{Binding ShowArtistListCommand}"
                        IsVisible="{Binding IsArtistDrilldownActive}" />
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding MobileHeaderTitle}"
                           FontWeight="SemiBold" />
            </Grid>

            <Border Grid.Row="1"
                    BorderThickness="1"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    Padding="8"
                    IsVisible="{Binding ShowMobileArtistsList}">
                <ListBox ItemsSource="{Binding Artists}"
                         SelectedItem="{Binding SelectedArtist}" />
            </Border>

            <Border Grid.Row="1"
                    BorderThickness="1"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    Padding="8"
                    IsVisible="{Binding ShowMobileSongsList}">
                <DataGrid ItemsSource="{Binding Songs}"
                          SelectedItem="{Binding SelectedSong}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Charter" Binding="{Binding Charter}" Width="160" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete Song (Server)" Command="{Binding DeleteSongCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </Grid>


    </Grid>

</UserControl>
