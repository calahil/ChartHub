<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:asyncImage="using:AsyncImageLoader"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="560"
             d:DesignHeight="400"
             x:Class="ChartHub.Views.SplashView"
             x:DataType="viewmodels:SplashViewModel">

    <Grid Background="{DynamicResource ThemeBackgroundBrush}">
         <Image asyncImage:ImageLoader.Source="avares://ChartHub/Resources/Images/logo-1024.png"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
    </Grid>

</UserControl>
