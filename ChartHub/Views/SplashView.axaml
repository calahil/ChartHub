<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:asyncImage="using:AsyncImageLoader"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             x:Class="ChartHub.Views.SplashView"
             x:DataType="viewmodels:SplashViewModel">

    <Grid Background="{DynamicResource ThemeBackgroundBrush}">
        <StackPanel HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Spacing="16">

            <!-- App name -->
            <Image asyncImage:ImageLoader.Source="avares://ChartHub/Resources/Images/logo.png"
                   VerticalAlignment="Stretch"
                   HorizontalAlignment="Stretch" />

        </StackPanel>
    </Grid>

</UserControl>
