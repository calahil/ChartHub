<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             x:Class="ChartHub.Views.VirtualKeyboardView"
             x:Name="Root"
             x:DataType="viewmodels:VirtualKeyboardViewModel"
             d:DesignWidth="600"
             d:DesignHeight="400">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Status bar -->
        <Border Grid.Row="0"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource ThemeBorderMidBrush}">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
        </Border>

        <!-- Hidden capture input box + special keys row -->
        <Grid Grid.Row="1" Margin="12,10,12,6" RowDefinitions="Auto,Auto">
            <!-- Hidden capture TextBox: captures IME/keyboard input, bound to InputBuffer -->
            <TextBox Grid.Row="0"
                     x:Name="CaptureBox"
                     Text="{Binding InputBuffer}"
                     PlaceholderText="{Binding PageStrings.KeyboardHint}"
                     AcceptsReturn="False"
                     IsVisible="True"
                     Margin="0,0,0,8" />

            <!-- Special keys row -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button Content="{Binding PageStrings.KeyEscape}"
                        CornerRadius="6"
                        MinWidth="60"
                        Height="40"
                        Command="{Binding SendEscapeCommand}" />
                <Button Content="{Binding PageStrings.KeyTab}"
                        CornerRadius="6"
                        MinWidth="60"
                        Height="40"
                        Command="{Binding SendTabCommand}" />
                <Button Content="{Binding PageStrings.KeyBackspace}"
                        CornerRadius="6"
                        MinWidth="60"
                        Height="40"
                        Command="{Binding SendBackspaceCommand}" />
                <Button Content="{Binding PageStrings.KeyEnter}"
                        CornerRadius="6"
                        MinWidth="80"
                        Height="40"
                        Command="{Binding SendEnterCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
