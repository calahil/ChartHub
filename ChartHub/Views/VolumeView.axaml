<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             x:Class="ChartHub.Views.VolumeView"
             x:Name="Root"
             x:DataType="viewmodels:VolumeViewModel"
             d:DesignWidth="1000"
             d:DesignHeight="720">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Volume Control"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="Control server master volume and active application sessions."
                               Foreground="{StaticResource ThemeForegroundLowBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding !IsBusy}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="10"
                    BorderThickness="1"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    Background="{StaticResource ThemeControlLowBrush}"
                    CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ThemeForegroundLowBrush}" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                IsVisible="{Binding IsAndroidHardwareBindingVisible}">
                        <TextBlock Text="Android volume buttons control server volume"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding IsAndroidHardwareBindingEnabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,10"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    Background="{StaticResource ThemeControlLowBrush}"
                    CornerRadius="8">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="10"
                      ColumnSpacing="12">
                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Text="Master Volume"
                               FontWeight="SemiBold"
                               FontSize="16" />

                    <Slider Grid.Row="1"
                            Minimum="0"
                            Maximum="100"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            Value="{Binding PendingMasterVolume}" />

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding PendingMasterVolume, StringFormat='Pending: {0}%'}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding MasterStateLabel}"
                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>

                    <Button Grid.Row="2"
                            Grid.Column="1"
                            Content="Apply Master"
                            Command="{Binding ApplyMasterCommand}"
                            IsEnabled="{Binding IsMasterDirty}" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Spacing="10">
                <TextBlock Text="Application Sessions"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <Border Padding="10"
                        BorderThickness="1"
                        BorderBrush="{StaticResource ThemeBorderMidBrush}"
                        Background="{StaticResource ThemeControlLowBrush}"
                        CornerRadius="8"
                    IsVisible="{Binding ShowPerApplicationUnsupportedMessage}">
                    <TextBlock Text="{Binding SessionSupportMessage}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ThemeForegroundLowBrush}" />
                </Border>

                <TextBlock Text="No active application audio sessions found."
                           IsVisible="{Binding ShowEmptySessionsMessage}"
                           Foreground="{StaticResource ThemeForegroundLowBrush}" />

                <ItemsControl ItemsSource="{Binding Sessions}"
                              IsVisible="{Binding HasSessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:VolumeSessionCardItem">
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                    Background="{StaticResource ThemeControlLowBrush}"
                                    CornerRadius="8">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="8"
                                      ColumnSpacing="12">
                                    <StackPanel Grid.Row="0"
                                                Grid.ColumnSpan="2"
                                                Spacing="2">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                   FontSize="11" />
                                    </StackPanel>

                                    <Slider Grid.Row="1"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="5"
                                            Value="{Binding PendingVolume}" />

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="1"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PendingVolume, StringFormat='Pending: {0}%'}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding CurrentLabel}"
                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <Button Grid.Row="2"
                                            Grid.Column="1"
                                            Content="Apply Session"
                                            Command="{Binding #Root.((viewmodels:VolumeViewModel)DataContext).ApplySessionCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding IsDirty}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>