<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ChartHub.Models"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="640"
             x:Name="Root"
             x:Class="ChartHub.Views.SyncView"
             x:DataType="viewmodels:SyncViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding SyncTitle}"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding SyncSubtitle}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ConnectionHint}"
                           IsVisible="{Binding HasConnectionHint}"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding AutoRefreshHint}"
                           IsVisible="{Binding IsCompanionMode}"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           Foreground="{DynamicResource SemanticError}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border IsVisible="{Binding HasDiagnosticsToDisplay}"
                    Padding="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DiagnosticsSummary}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <TextBlock Text="{Binding Diagnostics.LastErrorMessage, StringFormat='Error: {0}'}"
                               IsVisible="{Binding Diagnostics.HasLastErrorMessage}"
                               Foreground="{DynamicResource SemanticError}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Diagnostics.RemediationHint, StringFormat='Tip: {0}'}"
                               IsVisible="{Binding Diagnostics.HasRemediationHint}"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Diagnostics.LastAttemptDisplay, StringFormat='Last attempt: {0}'}"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowDesktopBootstrapSection}"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Desktop QR Pairing"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <TextBlock Text="{Binding BootstrapInstructions}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    <Button HorizontalAlignment="Left"
                        MinWidth="180"
                        Content="Refresh QR"
                        Command="{Binding RefreshDesktopQrCommand}" />
                    <Border IsVisible="{Binding ShowDesktopBootstrapPlaceholder}"
                            Padding="10"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            Background="{DynamicResource ThemeControlMidBrush}">
                        <TextBlock Text="{Binding BootstrapPlaceholderText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    </Border>
                    <Image IsVisible="{Binding HasBootstrapQrImage}"
                           Width="220"
                           Height="220"
                           HorizontalAlignment="Left"
                           Source="{Binding BootstrapQrImage}" />
                          <TextBox Text="{Binding BootstrapQrImageExportPath}"
                             IsReadOnly="True"
                             IsVisible="{Binding HasBootstrapQrImageExportPath}"
                             Watermark="Generated QR image path"
                             TextWrapping="Wrap" />
                    <TextBox Text="{Binding GeneratedBootstrapPayload}"
                             IsReadOnly="True"
                             Watermark="Generated bootstrap payload"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowCompanionScanSection}"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Scan Desktop QR"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <TextBlock Text="Use the desktop QR to start pairing. After confirmation, the companion connects automatically and opens the queue."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    <Button HorizontalAlignment="Left"
                            MinWidth="180"
                            Content="Scan Desktop QR"
                            IsVisible="{Binding SupportsCameraScanning}"
                            Command="{Binding ScanBootstrapQrCommand}" />

                    <Border IsVisible="{Binding ShowCompanionConfirmationSection}"
                            Padding="10"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            Background="{DynamicResource ThemeControlMidBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Ready To Pair"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeForegroundBrush}" />
                            <TextBlock Text="{Binding PendingQrPairingSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <WrapPanel Orientation="Horizontal"
                                       ItemHeight="36"
                                       ItemWidth="150">
                                <Button Margin="0,0,8,8"
                                        Content="Confirm Pairing"
                                        Command="{Binding ConfirmQrPairingCommand}" />
                                <Button Margin="0,0,8,8"
                                        Content="Cancel"
                                        Command="{Binding CancelPendingQrPairingCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowCompanionQueueSection}"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <StackPanel Spacing="8">
                    <Border IsVisible="{Binding ShowCompanionActivityStrip}"
                            Padding="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            Background="{DynamicResource ThemeControlMidBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding CompanionActivitySummary}"
                                       Foreground="{DynamicResource ThemeForegroundBrush}"
                                       TextWrapping="Wrap" />
                            <ProgressBar IsVisible="{Binding IsLocalPushInProgress}"
                                         Minimum="0"
                                         Maximum="{Binding LocalPushProgressMaximum}"
                                         Value="{Binding LocalPushProgressValue}"
                                         Height="6" />
                            <TextBlock Text="{Binding LocalPushCurrentFileName, StringFormat='Current file: {0}'}"
                                       IsVisible="{Binding HasLocalPushCurrentFileName}"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <WrapPanel Orientation="Horizontal"
                               ItemHeight="36"
                               ItemWidth="140">
                        <Button Margin="0,0,8,8"
                                Content="Refresh Queue"
                                Command="{Binding RefreshQueueCommand}" />
                        <Button Margin="0,0,8,8"
                                Content="Refresh Local"
                                Command="{Binding RefreshLocalFilesCommand}" />
                        <Button Margin="0,0,8,8"
                                Content="Push Selected"
                                Command="{Binding PushSelectedLocalFilesCommand}" />
                    </WrapPanel>

                    <Border IsVisible="{Binding ShowCompanionLocalFilesSection}"
                            Padding="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            Background="{DynamicResource ThemeControlMidBrush}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Local Files"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeForegroundBrush}" />
                            <ItemsControl ItemsSource="{Binding LocalFiles}"
                                          IsVisible="{Binding HasLocalFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,2">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding Checked}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,8,0"
                                                       Text="{Binding DisplayName}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource ThemeForegroundBrush}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FileSize}"
                                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No local files detected in the download directory."
                                       IsVisible="{Binding #Root.DataContext.ShowNoLocalFilesHint}"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding QueueItems}"
                                  IsVisible="{Binding HasQueueItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:IngestionQueueItem">
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                                        Background="{DynamicResource ThemeControlMidBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeForegroundBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding IngestionId, StringFormat='ID: {0}'}"
                                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                        <TextBlock Text="{Binding CurrentState, StringFormat='State: {0}'}"
                                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                        <TextBlock Text="{Binding DesktopState, StringFormat='Desktop: {0}'}"
                                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                        <TextBlock Text="{Binding UpdatedText, StringFormat='Updated: {0}'}"
                                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                             <WrapPanel Orientation="Horizontal"
                                                  IsVisible="{Binding HasActionResult}">
                                              <TextBlock Text="{Binding ActionResultStatusBadge}"
                                                      Margin="0,0,6,0"
                                                      Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                              <TextBlock Text="{Binding ActionResultDisplay, StringFormat='Last action: {0}'}"
                                                      Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                                      TextWrapping="Wrap" />
                                             </WrapPanel>
                                             <ProgressBar IsVisible="{Binding HasPendingActionResult}"
                                                    IsIndeterminate="True"
                                                    Height="4" />
                                        <WrapPanel Orientation="Horizontal"
                                                   ItemHeight="36"
                                                   ItemWidth="150">
                                            <Button Margin="0,0,8,8"
                                                    Content="Retry"
                                                Command="{Binding #Root.((viewmodels:SyncViewModel)DataContext).RetrySelectedCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Margin="0,0,8,8"
                                                    Content="Install"
                                                Command="{Binding #Root.((viewmodels:SyncViewModel)DataContext).InstallSelectedCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Margin="0,0,8,8"
                                                    Content="Open Folder"
                                                Command="{Binding #Root.((viewmodels:SyncViewModel)DataContext).OpenFolderSelectedCommand}"
                                                    CommandParameter="{Binding}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border IsVisible="{Binding ShowEmptyQueueState}"
                            Padding="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            Background="{DynamicResource ThemeControlMidBrush}">
                        <TextBlock Text="Connected, but there are no ingestion items queued right now."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    </Border>
                </StackPanel>
            </Border>

            <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" />
        </StackPanel>
    </ScrollViewer>
</UserControl>