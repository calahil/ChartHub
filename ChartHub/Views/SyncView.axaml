<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="640"
             x:Class="ChartHub.Views.SyncView"
             x:DataType="viewmodels:SyncViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="16">
        <TextBlock Grid.Row="0"
                   Text="Desktop Sync"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto" Margin="0,10,0,0">
            <TextBox Grid.Column="0"
                     Margin="0,0,8,0"
                     Watermark="Desktop host URL (example: http://192.168.1.10:15123)"
                     Text="{Binding DesktopApiBaseUrl}" />
            <TextBox Grid.Column="1"
                     Margin="0,0,8,0"
                     Watermark="Sync token"
                     Text="{Binding SyncToken}" />
            <Button Grid.Column="2"
                    MinWidth="130"
                    Command="{Binding TestConnectionCommand}"
                    Content="Connect" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,Auto,Auto" Margin="0,10,0,0">
            <TextBox Grid.Column="0"
                     Margin="0,0,8,0"
                     Watermark="Device label"
                     Text="{Binding DeviceLabel}" />
            <TextBox Grid.Column="1"
                     Margin="0,0,8,0"
                     Watermark="Pair code"
                     Text="{Binding PairCode}" />
            <Button Grid.Column="2"
                Margin="0,0,8,0"
                MinWidth="130"
                Command="{Binding PairWithCodeCommand}"
                Content="Pair + Connect" />
            <Button Grid.Column="3"
                    MinWidth="130"
                    Command="{Binding SaveProfileCommand}"
                    Content="Save Profile" />
        </Grid>

        <StackPanel Grid.Row="3" Spacing="6" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource ThemeForegroundBrush}" />
            <TextBlock Text="{Binding ConnectionHint}"
                       IsVisible="{Binding HasConnectionHint}"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            <TextBlock Text="{Binding AutoRefreshHint}"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       Foreground="{DynamicResource SemanticError}" />
            <Border IsVisible="{Binding HasDiagnosticsToDisplay}"
                    Padding="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DiagnosticsSummary}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <TextBlock Text="{Binding Diagnostics.LastErrorMessage, StringFormat='Error: {0}'}"
                               IsVisible="{Binding Diagnostics.LastErrorMessage, Converter={StaticResource NullToFalse}}"
                               Foreground="{DynamicResource SemanticError}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Diagnostics.RemediationHint, StringFormat='💡 {0}'}"
                               IsVisible="{Binding Diagnostics.RemediationHint, Converter={StaticResource NullToFalse}}"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Diagnostics.LastAttemptDisplay, StringFormat='Last attempt: {0}'}"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
            <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" />
        </StackPanel>

        <Grid Grid.Row="4" ColumnDefinitions="340,*" Margin="0,10,0,0">
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="0,0,10,0">
                <TextBlock Grid.Row="0"
                           Text="Saved Connections"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                    <Button Content="Apply"
                            Command="{Binding ApplyProfileCommand}"
                            CommandParameter="{Binding SelectedProfile}" />
                    <Button Content="Remove"
                            Command="{Binding RemoveProfileCommand}"
                            CommandParameter="{Binding SelectedProfile}" />
                </StackPanel>
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding SavedProfiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Host" Binding="{Binding BaseUrl}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh Queue"
                            Command="{Binding RefreshQueueCommand}" />
                    <Button Content="Retry Selected"
                            Command="{Binding RetrySelectedCommand}"
                            CommandParameter="{Binding SelectedItem}" />
                    <Button Content="Install Selected"
                            Command="{Binding InstallSelectedCommand}"
                            CommandParameter="{Binding SelectedItem}" />
                    <Button Content="Open Folder"
                            Command="{Binding OpenFolderSelectedCommand}"
                            CommandParameter="{Binding SelectedItem}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          Margin="0,8,0,0"
                          ItemsSource="{Binding QueueItems}"
                          SelectedItem="{Binding SelectedItem}"
                          IsVisible="{Binding HasQueueItems}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IngestionId}" Width="90" />
                        <DataGridTextColumn Header="Title" Binding="{Binding DisplayName}" Width="2*" />
                        <DataGridTextColumn Header="State" Binding="{Binding CurrentState}" Width="130" />
                        <DataGridTextColumn Header="Desktop" Binding="{Binding DesktopState}" Width="130" />
                        <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedText}" Width="190" />
                        <DataGridTextColumn Header="Last Action" Binding="{Binding ActionResultDisplay}" Width="180" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        IsVisible="{Binding ShowEmptyQueueState}"
                        Padding="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                        Background="{DynamicResource ThemeControlLowBrush}">
                    <TextBlock Text="Connected, but there are no ingestion items queued right now."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>