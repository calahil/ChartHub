<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ChartHub.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="560"
             d:DesignHeight="420"
             x:Class="ChartHub.Views.AuthGateView"
             x:DataType="viewmodels:AuthGateViewModel">

    <Grid RowDefinitions="*" ColumnDefinitions="*"
          Background="{DynamicResource ThemeBackgroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0">
            <Border MaxWidth="560"
                    Margin="16"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ThemeControlMidBrush}"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel Spacing="14">
                    <TextBlock Text="ChartHub Cloud Sync"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <TextBlock Text="{Binding DescriptionText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SemanticError}" />

                        <Button Content="{Binding SignInButtonText}"
                            Command="{Binding SignInCommand}"
                            HorizontalAlignment="Stretch"
                            MinHeight="44"
                            Padding="18,10"
                            Background="{DynamicResource ThemeAccentBrush}"
                            Foreground="{DynamicResource ButtonForeground}" />

                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsBusy}" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
