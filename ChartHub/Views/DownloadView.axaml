<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:ChartHub.ViewModels"
             xmlns:utilities="using:ChartHub.Utilities"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ChartHub.Views.DownloadView"
             x:DataType="viewmodels:DownloadViewModel">

    <UserControl.Resources>
        <utilities:AssetPathToImageConverter x:Key="AssetPathToImageConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Margin="10">
        <!-- Buttons -->
        <StackPanel Grid.Row="0"
                    Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="{Binding PageStrings.UploadCloud}"
                        HorizontalContentAlignment="Center"
                        Command="{Binding UploadCloud}"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding IsDesktopMode}"
                        Width="140" />
                <Button Content="Cloud To Local"
                        HorizontalContentAlignment="Center"
                        Command="{Binding DownloadCloudToLocal}"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding IsDesktopMode}"
                        Width="140" />
                <Button Content="Sync Cloud (Add)"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SyncCloudToLocal}"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding IsDesktopMode}"
                        Width="160" />
                <Button Content="{Binding PageStrings.InstallSongs}"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsAnyChecked}"
                        Command="{Binding InstallSongs}"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding IsDesktopMode}"
                        Width="140" />
            </StackPanel>

            <TextBlock Text="{Binding CloudConnectionHint}"
                       IsVisible="{Binding HasCloudConnectionHint}"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource ThemeForegroundLowBrush}"
                       FontSize="12" />
        </StackPanel>
        <Border Grid.Row="1"
                Margin="0,10,0,10"
                Padding="10"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                BorderThickness="1"
                IsVisible="{Binding IsInstallPanelVisible}">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                <Grid Grid.Row="0"
                        ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0"
                           Text="Install Progress"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                           Text="{Binding InstallCurrentItemName}"
                               Margin="10,0,0,0"
                           VerticalAlignment="Center" />
                    <Border Grid.Column="2"
                            Margin="10,0,0,0"
                        Background="{StaticResource ThemeControlLowBrush}"
                        CornerRadius="10"
                        Padding="8,2"
                        IsVisible="{Binding HasInstallSummary}">
                    <TextBlock Text="{Binding InstallSummaryText}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                    </Border>
                    <Button Grid.Column="3"
                            Margin="10,0,0,0"
                        Content="{Binding InstallLogToggleText}"
                        Command="{Binding ToggleInstallLogCommand}" />
                    <Button Grid.Column="4"
                            Margin="10,0,0,0"
                        Content="Clear Log"
                        Command="{Binding ClearInstallLogCommand}" />
                    <Button Grid.Column="5"
                            Margin="10,0,0,0"
                        Content="Cancel"
                        Command="{Binding CancelInstallCommand}"
                        IsEnabled="{Binding IsInstallActive}" />
                    <Button Grid.Column="6"
                            Margin="10,0,0,0"
                        Content="Dismiss"
                        Command="{Binding DismissInstallPanelCommand}"
                        IsEnabled="{Binding IsInstallIdle}" />
                </Grid>

                <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                           Text="{Binding InstallStageText}"
                           Foreground="{StaticResource ThemeForegroundLowBrush}" />

                <Grid Grid.Row="2"
                Margin="0,8,0,0"
                ColumnDefinitions="*,Auto">
                    <ProgressBar Grid.Column="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding InstallProgressValue}"
                                 IsIndeterminate="{Binding IsInstallProgressIndeterminate}" />
                    <TextBlock Grid.Column="1"
                     Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding InstallProgressValue, StringFormat={}{0:F0}%}" />
                </Grid>

                <TextBox Grid.Row="3"
                         x:Name="InstallLogTextBox"
                     Margin="0,8,0,0"
                         MinHeight="140"
                         Text="{Binding InstallLogText}"
                     IsVisible="{Binding IsInstallLogExpanded}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap" />
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Queue"
                     IsVisible="{Binding IsDesktopMode}"
                     FontSize="16">
                                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <TextBlock Text="State"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding QueueStateFilters}"
                                  SelectedItem="{Binding SelectedQueueStateFilter}"
                                  Width="170" />
                        <TextBlock Text="Sort"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding QueueSortOptions}"
                                  SelectedItem="{Binding SelectedQueueSort}"
                                  Width="140" />
                        <CheckBox Content="Descending"
                                  IsChecked="{Binding IsQueueSortDescending}"
                                  VerticalAlignment="Center" />
                    </StackPanel>

                        <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                            BorderThickness="1"
                            Padding="10">
                        <DataGrid ItemsSource="{Binding IngestionQueue}"
                                  CanUserSortColumns="False"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Install" Binding="{Binding Checked}" Width="80" />
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="220" />
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110" />
                                <DataGridTextColumn Header="State" Binding="{Binding CurrentState}" Width="120" />
                                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedText}" Width="170" />
                                <DataGridTextColumn Header="Downloaded Asset" Binding="{Binding DownloadedLocation}" Width="260" />
                                <DataGridTextColumn Header="Installed Dir" Binding="{Binding InstalledLocation}" Width="260" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Google Drive"
                     FontSize="16">
                <Border BorderBrush="{StaticResource ThemeBorderMidBrush}"
                        Grid.Column="0"
                        BorderThickness="1"
                        Padding="10">
                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding GoogleFiles}"
                              CanUserSortColumns="True"
                              AutoGenerateColumns="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Install" Binding="{Binding Checked}" Width="80" />
                            <DataGridTextColumn Header="{Binding PageStrings.DisplayName}" Binding="{Binding DisplayName}" />
                            <DataGridTemplateColumn Header="{Binding PageStrings.FileType}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate >
                                        <Image Source="{Binding ImageFile, Converter={StaticResource AssetPathToImageConverter}}"
                                               Height="48" Width="48" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{Binding PageStrings.FileSize}" Binding="{Binding FileSize}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

    </Grid>
</UserControl>
