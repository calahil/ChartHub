<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:ChartHub.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ChartHub.Views.DownloadView"
             x:DataType="viewmodels:DownloadViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="10">
        <!-- Buttons -->
        <StackPanel Grid.Row="0"
                    Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="{Binding PageStrings.InstallSongs}"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsAnyChecked}"
                        Command="{Binding InstallSongs}"
                        VerticalAlignment="Stretch"
                        Width="140" />
                <Button Content="Delete Selected"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsAnyChecked}"
                        Command="{Binding DeleteSelectedDownloadsCommand}"
                    VerticalAlignment="Stretch"
                        Width="140" />
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="1"
                Margin="0,10,0,10"
                Padding="10"
                BorderBrush="{StaticResource ThemeBorderMidBrush}"
                BorderThickness="1"
                IsVisible="{Binding IsInstallPanelVisible}">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                <Grid Grid.Row="0"
                        ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0"
                           Text="Install Progress"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                           Text="{Binding InstallCurrentItemName}"
                               Margin="10,0,0,0"
                           VerticalAlignment="Center" />
                    <Border Grid.Column="2"
                            Margin="10,0,0,0"
                        Background="{StaticResource ThemeControlLowBrush}"
                        CornerRadius="10"
                        Padding="8,2"
                        IsVisible="{Binding HasInstallSummary}">
                    <TextBlock Text="{Binding InstallSummaryText}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                    </Border>
                    <Button Grid.Column="3"
                            Margin="10,0,0,0"
                        Content="{Binding InstallLogToggleText}"
                        Command="{Binding ToggleInstallLogCommand}" />
                    <Button Grid.Column="4"
                            Margin="10,0,0,0"
                        Content="Clear Log"
                        Command="{Binding ClearInstallLogCommand}" />
                    <Button Grid.Column="5"
                            Margin="10,0,0,0"
                        Content="Cancel"
                        Command="{Binding CancelInstallCommand}"
                        IsEnabled="{Binding IsInstallActive}" />
                    <Button Grid.Column="6"
                            Margin="10,0,0,0"
                        Content="Dismiss"
                        Command="{Binding DismissInstallPanelCommand}"
                        IsEnabled="{Binding IsInstallIdle}" />
                </Grid>

                <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                           Text="{Binding InstallStageText}"
                           Foreground="{StaticResource ThemeForegroundLowBrush}" />

                <Grid Grid.Row="2"
                Margin="0,8,0,0"
                ColumnDefinitions="*,Auto">
                    <ProgressBar Grid.Column="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding InstallProgressValue}"
                                 IsIndeterminate="{Binding IsInstallProgressIndeterminate}" />
                    <TextBlock Grid.Column="1"
                     Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding InstallProgressValue, StringFormat={}{0:F0}%}" />
                </Grid>

                <Border Grid.Row="3"
                        Margin="0,8,0,0"
                        MinHeight="140"
                        MaxHeight="260"
                        BorderBrush="{StaticResource ThemeBorderMidBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding IsInstallLogExpanded}">
                    <ScrollViewer x:Name="InstallLogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy All Logs"
                                          IsEnabled="{Binding CanCopyAllInstallLogs}"
                                          Click="CopyAllLogs_Click" />
                            </ContextMenu>
                        </ScrollViewer.ContextMenu>
                        <ItemsControl x:Name="InstallLogItemsControl"
                                      ItemsSource="{Binding InstallLogItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4">
                                        <TextBlock Text="{Binding .}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy"
                                                              Click="CopyLogItem_Click" />
                                                </ContextMenu>
                                            </TextBlock.ContextMenu>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <TextBlock Text="State"
                           VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding QueueStateFilters}"
                          SelectedItem="{Binding SelectedQueueStateFilter}"
                          Width="170" />
                <TextBlock Text="Sort"
                           VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding QueueSortOptions}"
                          SelectedItem="{Binding SelectedQueueSort}"
                          Width="140" />
                <CheckBox Content="Descending"
                          IsChecked="{Binding IsQueueSortDescending}"
                          VerticalAlignment="Center" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasIngestionQueueItems}">
                        <ItemsControl ItemsSource="{Binding IngestionQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="10"
                                            CornerRadius="10"
                                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource ThemeControlLowBrush}">
                                        <Grid ColumnDefinitions="Auto,*"
                                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                            <CheckBox Grid.RowSpan="7"
                                                      IsChecked="{Binding Checked}"
                                                      VerticalAlignment="Top"
                                                      Margin="0,1,10,0" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="0"
                                                       Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="1"
                                                       Text="{Binding Source, StringFormat=Source: {0}}"
                                                       Margin="0,0,0,4"
                                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="2"
                                                       Text="{Binding CurrentState, StringFormat=State: {0}}"
                                                       Margin="0,0,0,4"
                                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="3"
                                                       Text="{Binding UpdatedText, StringFormat=Updated: {0}}"
                                                       Margin="0,0,0,4"
                                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="4"
                                                       Text="{Binding DownloadedLocation, StringFormat=Downloaded Asset: {0}}"
                                                       Margin="0,0,0,4"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="5"
                                                       Text="{Binding InstalledLocation, StringFormat=Installed Dir: {0}}"
                                                       Margin="0,0,0,4"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="6"
                                                       Text="{Binding ActionResultStatusBadge, StringFormat=Status: {0}}"
                                                       IsVisible="{Binding HasPendingActionResult}"
                                                       Foreground="{StaticResource ThemeAccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border IsVisible="{Binding ShowQueueEmptyState}"
                            Padding="10"
                            CornerRadius="10"
                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                            BorderThickness="1"
                            Background="{StaticResource ThemeControlLowBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="No downloads are available from ChartHub.Server with the current filters."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
