<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:ChartHub.ViewModels"
             xmlns:models="using:ChartHub.Models"
             xmlns:services="using:ChartHub.Services"
             xmlns:utilities="using:ChartHub.Utilities"
             xmlns:strings="using:ChartHub.Strings"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ChartHub.Views.DownloadView"
             x:DataType="viewmodels:DownloadViewModel">

    <UserControl.Resources>
        <utilities:DownloadFileTypeToIconConverter x:Key="DownloadFileTypeToIconConverter" />
        <utilities:AssetPathToImageConverter x:Key="AssetPathToImageConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Margin="10">
        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="{Binding PageStrings.InstallSongs}"
                        HorizontalContentAlignment="Center"
                        CornerRadius="10"
                        IsEnabled="{Binding IsAnyChecked}"
                        Command="{Binding InstallSongs}"
                        VerticalAlignment="Stretch"
                        Width="140" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                    <TextBlock Text="{Binding PageStrings.StateLabel}"
                           VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding QueueStateFilters}"
                          SelectedItem="{Binding SelectedQueueStateFilter}"
                          Width="170" />
                    <TextBlock Text="{Binding PageStrings.SortLabel}"
                           VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding QueueSortOptions}"
                          SelectedItem="{Binding SelectedQueueSort}"
                          Width="140" />
                    <CheckBox Content="{Binding PageStrings.Descending}"
                          IsChecked="{Binding IsQueueSortDescending}"
                          VerticalAlignment="Center" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasIngestionQueueItems}">
                        <ItemsControl x:Name="QueueItemsControl"
                                      ItemsSource="{Binding IngestionQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:IngestionQueueItem">
                                    <Border Margin="0,0,0,6"
                                            Padding="10"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource ThemeControlLowBrush}">
                                        <StackPanel Spacing="6">
                                            <!-- Main card row -->
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                <!-- Checkbox -->
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding Checked}"
                                                          VerticalAlignment="Top"
                                                          Margin="0,2,8,0" />
                                                <!-- Filetype icon -->
                                                <Image Grid.Column="1"
                                                       Width="28"
                                                       Height="28"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,10,0"
                                                       Source="{Binding FileType, Converter={StaticResource DownloadFileTypeToIconConverter}}" />
                                                <!-- Info stack -->
                                                <StackPanel Grid.Column="2"
                                                            Spacing="3"
                                                            VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DownloadedFilename}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                               IsVisible="{Binding DownloadedFilename, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="4"
                                                                IsVisible="{Binding Artist, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                                   Text="{Binding #QueueItemsControl.((viewmodels:DownloadViewModel)DataContext).PageStrings.ArtistLabel}" />
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                                   Text="{Binding Artist}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="4"
                                                                IsVisible="{Binding Charter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                                   Text="{Binding #QueueItemsControl.((viewmodels:DownloadViewModel)DataContext).PageStrings.CharterLabel}" />
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                                   Text="{Binding Charter}" />
                                                    </StackPanel>
                                                    <ProgressBar Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding ProgressPercent}"
                                                                 Height="6"
                                                                 IsVisible="{Binding IsProgressVisible}"
                                                                 Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding CurrentState}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource ThemeForegroundLowBrush}" />
                                                    <TextBlock Text="{Binding ConversionWarningMessage}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource SemanticWarning}"
                                                               IsVisible="{Binding ConversionWarningMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <!-- Inline delete button -->
                                                <Button Grid.Column="3"
                                                        VerticalAlignment="Top"
                                                        Width="28"
                                                        Height="28"
                                                        CornerRadius="10"
                                                        Padding="0"
                                                        Margin="8,0,0,0"
                                                        ToolTip.Tip="{Binding #QueueItemsControl.((viewmodels:DownloadViewModel)DataContext).PageStrings.DeleteJob}"
                                                        Command="{Binding #QueueItemsControl.((viewmodels:DownloadViewModel)DataContext).DeleteJobCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Image Width="18"
                                                           Height="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Source="{Binding Source={x:Static strings:UiIcons.DeleteButton}, Converter={StaticResource AssetPathToImageConverter}, ConverterParameter='#ED8796'}" />
                                                </Button>
                                            </Grid>
                                            <!-- Log toggle button -->
                                            <Button HorizontalAlignment="Left"
                                                    CornerRadius="6"
                                                    Padding="8,3"
                                                    FontSize="11"
                                                    Content="{Binding JobLogToggleText}"
                                                    Command="{Binding #QueueItemsControl.((viewmodels:DownloadViewModel)DataContext).ToggleJobLogCommand}"
                                                    CommandParameter="{Binding}" />
                                            <!-- Collapsible log panel -->
                                            <Border IsVisible="{Binding IsJobLogExpanded}"
                                                    BorderBrush="{StaticResource ThemeBorderMidBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6">
                                                <Grid RowDefinitions="Auto,*">
                                                    <TextBlock Grid.Row="0"
                                                               Text="Loading…"
                                                               FontSize="11"
                                                               Foreground="{StaticResource ThemeForegroundLowBrush}"
                                                               IsVisible="{Binding IsLoadingLogs}"
                                                               Margin="0,0,0,4" />
                                                    <ScrollViewer Grid.Row="1"
                                                                  MaxHeight="200"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                                        <ItemsControl ItemsSource="{Binding JobLogs}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="services:ChartHubServerJobLogEntry">
                                                                    <TextBlock FontSize="10"
                                                                               FontFamily="Monospace"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,1"
                                                                               Text="{Binding Message}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border IsVisible="{Binding ShowQueueEmptyState}"
                            Padding="10"
                            CornerRadius="8"
                            BorderBrush="{StaticResource ThemeBorderMidBrush}"
                            BorderThickness="1"
                            Background="{StaticResource ThemeControlLowBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding PageStrings.EmptyState}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ThemeForegroundLowBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
