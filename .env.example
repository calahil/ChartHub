# Docker Compose local defaults for PostgreSQL
PSQL_CONTAINER_NAME=charthub-postgres
PSQL_USER=postgres
PSQL_PASSWORD=CHANGE_ME
PSQL_DB=charthub_backup
INTERNAL=charthub_internal
DB_VOLUME=charthub-data

# Backup API runtime settings
RHYTHMVERSE_BASE_URL=https://rhythmverse.co/
RHYTHMVERSE_TOKEN=CHANGE_ME
BACKUP_SYNC_ENABLED=true
BACKUP_SYNC_INITIAL_DELAY_MINUTES=0
BACKUP_DOWNLOADS_MODE=redirect
BACKUP_DOWNLOADS_EXTERNAL_REDIRECT_CACHE_HOURS=48
BACKUP_DOWNLOADS_HOST_PATH=./ChartHub.BackupApi/cache/downloads
BACKUP_IMAGES_HOST_PATH=./ChartHub.BackupApi/cache/images

# ChartHub.Server runtime settings
CHARTHUB_SERVER_IMAGE=charthub-server:local
CHARTHUB_SERVER_CONTAINER_NAME=charthub-server
CHARTHUB_SERVER_ENVIRONMENT=Production
CHARTHUB_SERVER_PORT=5180
CHARTHUB_SERVER_JWT_SIGNING_KEY=CHANGE_ME_WITH_A_32_CHAR_MINIMUM_SECRET
CHARTHUB_SERVER_JWT_ISSUER=charthub-server
CHARTHUB_SERVER_JWT_AUDIENCE=charthub-clients
CHARTHUB_SERVER_ALLOWED_EMAIL_0=
CHARTHUB_SERVER_GOOGLE_DRIVE_API_KEY=
CHARTHUB_SERVER_CONFIG_PATH=./dev-data/config
CHARTHUB_SERVER_CHARTHUB_PATH=./dev-data/charthub
CHARTHUB_SERVER_CLONEHERO_PATH=./dev-data/clonehero
