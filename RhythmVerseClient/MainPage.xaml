<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
            xmlns:local="clr-namespace:RhythmVerseClient"
            x:Class="RhythmVerseClient.MainPage"
            xmlns:models="clr-namespace:RhythmVerseClient.ViewModels"
            xmlns:services="clr-namespace:RhythmVerseClient.Services"
            xmlns:control="clr-namespace:RhythmVerseClient.Controls">

    <ContentPage Title="RhythmVerse">
        <StackLayout>
            <Label Text="Welcome to Tab 1"
                   VerticalOptions="CenterAndExpand" 
                   HorizontalOptions="CenterAndExpand" />
            <Button Text="Click Me" 
                    VerticalOptions="CenterAndExpand" 
                    HorizontalOptions="CenterAndExpand" 
                    Clicked="OnButtonClicked" />
        </StackLayout>
    </ContentPage>

    <ContentPage Title="Downloads" x:Name="DownloadPage" x:DataType="models:DownloadViewModel">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Grid -->
            <Grid Grid.Row="0" ColumnSpacing="5" Padding="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" HorizontalOptions="Fill" VerticalOptions="Center">
                    <Button Command="{Binding CheckAllCommand}" HorizontalOptions="Fill" />
                    <CheckBox IsChecked="{Binding IsAllChecked}" VerticalOptions="Center" HorizontalOptions="Center" Opacity="100" Color="#000000" IsEnabled="True"/>
                </Grid>
                <!--<CheckBox Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="False">
                    <CheckBox.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="CheckedChanged" Command="{Binding CheckAllCommand}" />
                    </CheckBox.Behaviors>
                </CheckBox>-->
                <!--<Button Grid.Column="0" FontAttributes="Bold" HorizontalOptions="Fill" Command="{Binding SortCommand}" CommandParameter="FileSize" />-->
                <Button Text="Display Name" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="Fill" Command="{Binding SortCommand}" CommandParameter="DisplayName" />
                <Button Text="File Type" Grid.Column="2" FontAttributes="Bold" HorizontalOptions="Fill" Command="{Binding SortCommand}" CommandParameter="FileType" />
                <Button Text="File Size" Grid.Column="3" FontAttributes="Bold" HorizontalOptions="Fill" Command="{Binding SortCommand}" CommandParameter="FileSize" />
            </Grid>
            
            <CollectionView ItemsSource="{Binding DataItems}" SelectionMode="Single"
                        x:Name="DownloadList" Grid.Row="1">
            <CollectionView.ItemsLayout>
                <!-- Set Span to 1 for single item per row -->
                <GridItemsLayout Orientation="Vertical" Span="1" />
            </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:FileData">
                        <Grid ColumnSpacing="5" Padding="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox IsChecked="{Binding Checked}" Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" />                           
                            <control:FancyName Grid.Column="1" />
                            <Label Text="{Binding FileType}" Grid.Column="2" HorizontalOptions="Center" />
                            <Label Text="{Binding FileSize}" Grid.Column="3" HorizontalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage>

    <ContentPage Title="Clone Hero Songs" x:Name="CloneHeroPage">
        <CollectionView ItemsSource="{Binding CloneHeroSongsWatcher.Data}" SelectionMode="Single"
                        x:Name="CloneHeroList">
            <CollectionView.ItemsLayout>
                <!-- Set Span to 1 for single item per row -->
                <GridItemsLayout Orientation="Vertical" Span="1" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:FileData">
                    <Grid Padding="10" ColumnSpacing="5">
                        <!-- Define one row and two columns -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Bind properties to labels -->
                        <Image Source="{Binding ImageFile}" Grid.Row="0" Grid.Column="0" Aspect="AspectFill" />
                        <Label Text="{Binding DisplayName}" Grid.Row="0" Grid.Column="1" FontAutoScalingEnabled="False" VerticalTextAlignment="Center" />
                        <Label Text="{Binding FileSize}" Grid.Row="0" Grid.Column="2" FontAutoScalingEnabled="False" VerticalTextAlignment="Center" />
                        <Label Text="{Binding FileType}" Grid.Row="0" Grid.Column="3" FontAutoScalingEnabled="False" VerticalTextAlignment="Center" />
                        <Label Text="{Binding FilePath}" Grid.Row="0" Grid.Column="4" FontAutoScalingEnabled="False" VerticalTextAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ContentPage>

    <ContentPage Title="Settings">
        <StackLayout>
            <Label Text="Welcome to Tab 4"
                   VerticalOptions="CenterAndExpand" 
                   HorizontalOptions="CenterAndExpand" />
            <Slider Minimum="0" Maximum="100"
                    VerticalOptions="CenterAndExpand" 
                    HorizontalOptions="CenterAndExpand" />
        </StackLayout>
    </ContentPage>

</TabbedPage>