<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RhythmVerseClient.Controls.FancyName">
    
    <Grid ColumnSpacing="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Source="{Binding ImageFile}" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" Grid.Column="0"/>
        <Label Text="{Binding DisplayName}" VerticalOptions="Center" Grid.Column="1"/>
    </Grid>
</ContentView>
