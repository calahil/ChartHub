<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RhythmVerseClient.Views.InstallSongView">

    <StackPanel Margin="10" Spacing="10">
        <!-- Progress Bar Frame -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="2">
            <Grid RowDefinitions="*">
                <ProgressBar Value="{Binding ProgressValue}" IsIndeterminate="False" />
                <TextBlock Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"
                          Text="{Binding ProgressValue, StringFormat=0.0\%}" />
            </Grid>
        </Border>

        <!-- Buttons and Count -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <!-- Start Button -->
            <Button Content="{Binding PageString.StartButton}"
                    Height="32"
                    Command="{Binding StartBarCommand}" />

            <!-- Go Back Button -->
            <Button Content="{Binding PageString.GoBack}"
                    Height="32"
                    Command="{Binding GoBackCommand}" />

            <!-- Count Label -->
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                       Text="{Binding PhaseshiftWatcher.Data.Count, StringFormat='0 Items'}" />
        </StackPanel>

        <!-- Console Output -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Height="300">
            <TextBox Text="{Binding Details}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" />
        </Border>
    </StackPanel>

</UserControl>
