<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="RhythmVerseClient.Views.MainView"
        Title="RhythmVerseClient" Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <TabControl>
        <TabItem Header="RhythmVerse">
            <!-- RhythmVerseView will be included here -->
            <TextBlock Text="RhythmVerse View" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </TabItem>
        <TabItem Header="Download">
            <!-- DownloadView will be included here -->
            <TextBlock Text="Download View" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </TabItem>
        <TabItem Header="CloneHero">
            <!-- CloneHeroView will be included here -->
            <TextBlock Text="CloneHero View" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </TabItem>
        <TabItem Header="Install Song">
            <!-- InstallSongView will be included here -->
            <TextBlock Text="Install Song View" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </TabItem>
    </TabControl>

</Window>
