<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:Views="using:RhythmVerseClient.Views"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
         x:Class="RhythmVerseClient.Views.MainView">

    
    <TabControl>
        <TabItem Header="RhythmVerse"
                FontSize="16">
            <ContentControl Content="{Binding RhythmVerseViewModel}" />
        </TabItem>
        <TabItem Header="Download"
                FontSize="16"
                IsVisible="{Binding IsDownloadTabVisible}">
            <ContentControl Content="{Binding DownloadViewModel}" />
        </TabItem>
        <TabItem Header="CloneHero"
                FontSize="16"
                IsVisible="{Binding IsCloneHeroTabVisible}">
            <ContentControl Content="{Binding CloneHeroViewModel}" />
        </TabItem>
        <TabItem Header="Install Song"
                FontSize="16"
                IsVisible="{Binding IsInstallSongTabVisible}">
            <ContentControl Content="{Binding InstallSongViewModel}" />
        </TabItem>
    </TabControl>

</UserControl>
