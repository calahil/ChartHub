<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="RhythmVerseClient.Views.LoadingView">

    <Grid RowDefinitions="Auto,Auto" HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- ActivityIndicator (using TextBlock with animated progress) -->
        <ProgressBar Grid.Row="0" IsIndeterminate="True" Width="200" Height="50" />
        <TextBlock Grid.Row="1" Text="Initializing..." HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0" />
    </Grid>

</UserControl>
