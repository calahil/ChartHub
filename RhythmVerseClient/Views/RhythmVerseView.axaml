<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:RhythmVerseClient.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="RhythmVerseClient.Views.RhythmVerseView"
             x:DataType="viewmodels:RhythmVerseModel">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
        <!-- Search and Filter Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="300,100,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,100"
              Margin="10" Height="48">
            <TextBox Grid.Column="0" Watermark="Search text..." Text="{Binding SearchText}" />
            <TextBox Grid.Column="1" Watermark="Author..." Text="{Binding SearchAuthorText}" />
            <TextBlock Grid.Column="2" Text="|  Pages:" VerticalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="{Binding CurrentPage}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="/" VerticalAlignment="Center" />
            <TextBlock Grid.Column="5" Text="{Binding TotalPages}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="6" Text="|  Total:" VerticalAlignment="Center" />
            <TextBlock Grid.Column="7" Text="{Binding TotalResults}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="8" Text="Results:" VerticalAlignment="Center" />
            <Button Grid.Column="9" Content="Refresh" Command="{Binding RefreshButtonCommand}" HorizontalAlignment="Right" />
            <Button Grid.Column="10" Content="{Binding FilterPaneButtonText}" Command="{Binding ToggleFilterPaneCommand}" />
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" RowDefinitions="*" Margin="10">
            <!-- Song List -->
            <ListBox Grid.Column="0" ItemsSource="{Binding DataItems}" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,10" Padding="10" CornerRadius="5">
                            <Grid ColumnDefinitions="*,200" RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- Song Info -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Artist}" FontSize="16" FontWeight="Bold" Margin="0,0,0,5" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Title}" FontSize="16" Margin="0,0,0,5" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Album}" FontSize="12" Margin="0,0,0,5" />
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Spacing="20">
                                    <TextBlock Text="{Binding FormattedTime, StringFormat='Time: {0}'}" FontSize="12" />
                                    <TextBlock Text="{Binding Year, StringFormat='Released: {0}'}" FontSize="12" />
                                </StackPanel>

                                <!-- Download Info -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Spacing="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding DownloadCount, StringFormat='Downloads: {0}'}" FontSize="12" TextAlignment="Right" />
                                    <TextBlock Text="{Binding FileSize, StringFormat='Size: {0}'}" FontSize="12" TextAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Filter Pane (Collapsible) -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" 
                    IsVisible="{Binding IsFilterPaneVisible}" Width="300" Margin="10,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Filters" FontSize="16" FontWeight="Bold" />
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Sort By:" FontWeight="Bold" />
                            <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}" />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Order:" FontWeight="Bold" />
                            <ComboBox ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}" />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Instruments:" FontWeight="Bold" />
                            <ListBox ItemsSource="{Binding Instruments}" SelectedItems="{Binding SelectedInstruments}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <Button Content="Apply Filters" Command="{Binding RefreshButtonCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</UserControl>
