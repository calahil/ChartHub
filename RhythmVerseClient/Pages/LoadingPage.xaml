<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RhythmVerseClient.Pages.LoadingPage"
             Title="LoadingPage">

    <Grid RowDefinitions="Auto, Auto" HorizontalOptions="Center" VerticalOptions="Center">
        <ActivityIndicator Grid.Row="0" IsRunning="True" VerticalOptions="Center" HorizontalOptions="Center" />
        <Label Grid.Row="1" Text="Initializing..." VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>