root = true

[*.cs]
# Repo-wide style and analyzer policy.

# Import ordering/grouping
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace:error

# Modern C# style
csharp_prefer_simple_using_statement = true:error
csharp_style_namespace_declarations = file_scoped:error
csharp_prefer_braces = true:error
dotnet_style_readonly_field = true:error

# var policy (balanced strictness): use var when type is apparent, otherwise explicit
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_for_built_in_types = false:error
csharp_style_var_elsewhere = false:error

# Private naming: instance fields use _camelCase; private constants/static fields stay PascalCase.
dotnet_naming_rule.private_instance_fields_should_be_underscore_camel.symbols = private_instance_fields
dotnet_naming_rule.private_instance_fields_should_be_underscore_camel.style = underscore_camel
dotnet_naming_rule.private_instance_fields_should_be_underscore_camel.severity = error

dotnet_naming_rule.private_static_fields_should_be_underscore_camel.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_should_be_underscore_camel.style = underscore_camel
dotnet_naming_rule.private_static_fields_should_be_underscore_camel.severity = error

dotnet_naming_rule.private_static_readonly_fields_should_be_pascal_case.symbols = private_static_readonly_fields
dotnet_naming_rule.private_static_readonly_fields_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.private_static_readonly_fields_should_be_pascal_case.severity = error

dotnet_naming_rule.private_const_fields_should_be_pascal_case.symbols = private_const_fields
dotnet_naming_rule.private_const_fields_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.private_const_fields_should_be_pascal_case.severity = error

dotnet_naming_symbols.private_instance_fields.applicable_kinds = field
dotnet_naming_symbols.private_instance_fields.applicable_accessibilities = private

dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_static_fields.required_modifiers = static

dotnet_naming_symbols.private_static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_readonly_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_static_readonly_fields.required_modifiers = static, readonly

dotnet_naming_symbols.private_const_fields.applicable_kinds = field
dotnet_naming_symbols.private_const_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_const_fields.required_modifiers = const

dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.pascal_case.capitalization = pascal_case

# Escalate naming diagnostics to errors across the repo.
dotnet_diagnostic.IDE1006.severity = error

# IDE0051: Remove unused private member
dotnet_diagnostic.IDE0051.severity = error

# IDE0052: Remove unread private member (assigned but never read)
dotnet_diagnostic.IDE0052.severity = error

# IDE0060: Remove unused parameter
# Kept at suggestion to reduce noise from virtual/override/handler signatures
dotnet_diagnostic.IDE0060.severity = suggestion

# App-focused strictness: keep high-signal rules hard and demote noisy/library-centric guidance.
dotnet_diagnostic.CA1031.severity = suggestion
dotnet_diagnostic.CA1054.severity = suggestion
dotnet_diagnostic.CA1056.severity = suggestion
dotnet_diagnostic.CA1062.severity = suggestion
dotnet_diagnostic.CA1305.severity = suggestion
dotnet_diagnostic.CA1307.severity = suggestion
dotnet_diagnostic.CA1308.severity = suggestion
dotnet_diagnostic.CA1310.severity = suggestion
dotnet_diagnostic.CA1708.severity = suggestion
dotnet_diagnostic.CA1711.severity = suggestion
dotnet_diagnostic.CA1720.severity = suggestion
dotnet_diagnostic.CA1805.severity = suggestion
dotnet_diagnostic.CA1816.severity = suggestion
dotnet_diagnostic.CA1822.severity = suggestion
dotnet_diagnostic.CA1826.severity = suggestion
dotnet_diagnostic.CA1852.severity = suggestion
dotnet_diagnostic.CA1859.severity = suggestion
dotnet_diagnostic.CA1861.severity = suggestion
dotnet_diagnostic.CA1865.severity = suggestion
dotnet_diagnostic.CA1866.severity = suggestion
dotnet_diagnostic.CA1868.severity = suggestion
dotnet_diagnostic.CA1869.severity = suggestion
dotnet_diagnostic.CA2016.severity = suggestion
dotnet_diagnostic.CA2201.severity = suggestion
dotnet_diagnostic.CA1304.severity = suggestion
dotnet_diagnostic.CA1311.severity = suggestion
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1051.severity = none
dotnet_diagnostic.CA1068.severity = suggestion
dotnet_diagnostic.CA1001.severity = suggestion
dotnet_diagnostic.CA1849.severity = none
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA2227.severity = suggestion

[ChartHub.Tests/*.cs]
dotnet_diagnostic.CA1707.severity = none

[ChartHub.BackupApi.Tests/*.cs]
dotnet_diagnostic.CA1707.severity = none

[ChartHub/Models/APIRootResponse.cs]
generated_code = true

# ---- Per-file suppressions ----

# IGoogleAuthProvider.cs contains AndroidGoogleAuthProvider whose private helpers
# are called exclusively from within #if ANDROID blocks.  The net10.0 (desktop)
# build excludes those call sites via the preprocessor, so the analyzer flags the
# methods as unused — this is a known false-positive pattern for #if guards.
# Temporary and intentional: retained to avoid false-positive build breaks until
# platform-specific analyzer suppression can be made conditional by target framework.
[ChartHub/Services/IGoogleAuthProvider.cs]
dotnet_diagnostic.IDE0051.severity = none

# Treat generated files as generated code to reduce analyzer/style noise.
[*.g.cs]
generated_code = true

[*.g.i.cs]
generated_code = true

[*.designer.cs]
generated_code = true

[*.Designer.cs]
generated_code = true
