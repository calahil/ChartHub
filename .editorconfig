root = true

[*.cs]
# Unused-code detection (report-only — warnings, not errors)

# Import ordering/grouping
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace:warning

# Modern C# style
csharp_prefer_simple_using_statement = true:warning
csharp_style_namespace_declarations = file_scoped:warning
csharp_prefer_braces = true:warning
dotnet_style_readonly_field = true:warning

# var policy (balanced strictness): use var when type is apparent, otherwise explicit
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_elsewhere = false:warning

# Private field naming: underscore camel case (example: _someField)
dotnet_naming_rule.private_fields_should_be_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_underscore_camel.style = underscore_camel
dotnet_naming_rule.private_fields_should_be_underscore_camel.severity = warning
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case

# IDE0051: Remove unused private member
dotnet_diagnostic.IDE0051.severity = warning

# IDE0052: Remove unread private member (assigned but never read)
dotnet_diagnostic.IDE0052.severity = warning

# IDE0060: Remove unused parameter
# Kept at suggestion to reduce noise from virtual/override/handler signatures
dotnet_diagnostic.IDE0060.severity = suggestion

# ---- Per-file suppressions ----

# IGoogleAuthProvider.cs contains AndroidGoogleAuthProvider whose private helpers
# are called exclusively from within #if ANDROID blocks.  The net10.0 (desktop)
# build excludes those call sites via the preprocessor, so the analyzer flags the
# methods as unused — this is a known false-positive pattern for #if guards.
[ChartHub/Services/IGoogleAuthProvider.cs]
dotnet_diagnostic.IDE0051.severity = none

# Treat generated files as generated code to reduce analyzer/style noise.
[*.g.cs]
generated_code = true

[*.g.i.cs]
generated_code = true

[*.designer.cs]
generated_code = true

[*.Designer.cs]
generated_code = true
