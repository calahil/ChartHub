{
  "Auth": {
    "JwtSigningKey": "CHANGE_ME_WITH_A_32_CHAR_MINIMUM_SECRET",
    "Issuer": "charthub-server",
    "Audience": "charthub-clients",
    "AccessTokenMinutes": 60,
    "AllowedEmails": []
  },
  "GoogleAuth": {
    "AllowedAudiences": []
  },
  "GoogleDrive": {
    "ApiKey": ""
  },
  "ServerPaths": {
    "ConfigRoot": "dev-data/config",
    "ChartHubRoot": "dev-data/charthub",
    "DownloadsDir": "dev-data/charthub/downloads",
    "StagingDir": "dev-data/charthub/staging",
    "CloneHeroRoot": "dev-data/clonehero",
    "SqliteDbPath": "dev-data/config/charthub-server.db"
  },
  "Downloads": {
    "CompletedJobRetentionDays": 7
  },
  "DesktopEntry": {
    "Enabled": true,
    "CatalogDirectory": "/srv/games/desktop",
    "IconCacheDirectory": "cache/desktop-entry-icons",
    "SseIntervalSeconds": 2
  },
  "UnityLaunch": {
    "Enabled": true,
    "BootConfig": {
      "gfx-enable-gfx-jobs": "1",
      "gfx-enable-native-gfx-jobs": "1",
      "gc-max-time-slice": "3",
      "job-worker-count": "1",
      "player-connection-debug": "0"
    },
    "EnvironmentVariables": {
      "mesa_glthread": "true",
      "MESA_NO_ERROR": "1",
      "GALLIUM_DRIVER": "radeonsi",
      "PULSE_LATENCY_MSEC": "60",
      "SDL_AUDIODRIVER": "pulse"
    }
  },
  "ServerLogging": {
    "LogDirectory": "logs",
    "FileName": "charthub-server.log"
  },
  "AllowedHosts": "*",
  "Hud": {
    "ExecutablePath": "",
    "ServerPort": 5000
  }
}
